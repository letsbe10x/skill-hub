{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Index Entry",
  "description": "A single evidence claim backed by file references",
  "type": "object",
  "required": ["claim", "module", "sources", "confidence"],
  "properties": {
    "claim": {
      "type": "string",
      "description": "The factual claim about the codebase"
    },
    "module": {
      "type": "string",
      "description": "Module path this claim applies to"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "role"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Relative path from repo root"
          },
          "role": {
            "type": "string",
            "description": "What this file proves about the claim"
          }
        }
      },
      "minItems": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score. >=0.8 for non-negotiables, >=0.6 for conventions"
    },
    "category": {
      "type": "string",
      "enum": ["invariant", "boundary", "convention", "pattern", "tech-stack", "command"]
    }
  }
}
